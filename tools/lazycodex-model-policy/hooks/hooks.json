{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(spawn_agent|collaborationspawn_agent|collaboration\\.spawn_agent)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/reconcile.mjs\"",
            "timeout": 5,
            "statusMessage": "Applying LazyCodex model policy"
          }
        ]
      }
    ]
  }
}
